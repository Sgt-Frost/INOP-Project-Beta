            "characters": [],
            "dialogue": [
                {
                    "speaker": "Narrador",
                    "text": "Bajo el manto de la noche, las tropas sandinistas atacan un campamento enemigo.",
                    "portrait": "assets/images/portraits/narrator.jpg"
                },
                {
                    "speaker": "Sandino General",
                    "text": "¡Fuego! ¡Por Nicaragua libre!",
                    "portrait": "assets/images/portraits/sandino.jpg"
                },
                {
                    "speaker": "Narrador",
                    "text": "La táctica de guerrilla frustra a los invasores. No pueden vencer a un pueblo que lucha por su libertad.",
                    "portrait": "assets/images/portraits/narrator.jpg"
                }
            ],
